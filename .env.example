# Required for the default NVIDIA NIM endpoint.
NVIDIA_API_KEY=nvapi-your-key-here

# Defaults target NVIDIA's OpenAI-compatible GLM-5.2 free endpoint.
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=z-ai/glm-5.2
OPENAI_USE_PROVIDER_EXTRAS=true
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT_MS=600000
OPENAI_POLL_INTERVAL_MS=1000
DEBUG_LLM=false

# Minecraft WebSocket server. Connect from Bedrock with /connect localhost:3000
MC_WS_HOST=0.0.0.0
MC_WS_PORT=3000
MC_AI_PREFIX=!ai

# Keep below Bedrock's pending command limit. 50 leaves room for status messages.
MC_MAX_IN_FLIGHT=50
MC_COMMAND_DELAY_MS=0

# Comma-separated command names to reject from model output. Set blank to disable.
MC_BLOCKED_COMMANDS=connect,wsserver,stop,kick,ban,ban-ip,pardon,op,deop,allowlist,whitelist,save,reload,transfer

# Comma-separated command names allowed from model output. Set * to allow unknown commands.
MC_ALLOWED_COMMANDS=ability,alwaysday,camera,camerashake,clear,clearspawnpoint,clone,controlscheme,damage,daylock,dialogue,difficulty,effect,enchant,event,execute,fill,fog,function,gamemode,gamerule,give,help,hud,inputpermission,locate,loot,me,mobevent,music,particle,place,playanimation,playsound,recipe,replaceitem,ride,say,schedule,scoreboard,scriptevent,setblock,setmaxplayers,setworldspawn,spawnpoint,spreadplayers,stopsound,structure,summon,tag,teleport,tell,tellraw,testfor,testforblock,testforblocks,tickingarea,time,title,titleraw,toggledownfall,tp,weather,w,msg,xp

# Use true to preview queued commands in the terminal without sending them to Minecraft.
DRY_RUN_COMMANDS=false
